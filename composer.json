{
	"name": "forxer/gravatar",
	"description": "A library providing easy gravatar integration.",
	"homepage": "https://github.com/forxer/gravatar",
	"keywords": [
		"gravatar",
		"php"
	],
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Vincent Garnier",
			"email": "forxer@gmail.org"
		}
	],
	"support": {
		"issues": "https://github.com/forxer/gravatar/issues",
		"email": "forxer@gmail.com"
	},
	"require": {
		"php": "^8.4"
	},
    "require-dev": {
		"laravel/pint": "^1.29.0",
		"pestphp/pest": "*",
		"phpstan/phpstan": "^2.1",
		"rector/rector": "^2.3.9"
	},
	"autoload": {
		"psr-4": {
			"Gravatar\\": "src"
		}
	},
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
    },
    "scripts": {
        "lint": "pint --test",
        "fix": "pint",
        "analyse": "phpstan analyse",
        "refactor": "rector",
        "test": "pest",
        "check": ["@lint", "@analyse", "@test"]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
